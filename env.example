# ============================================
# Midscene AI Model Configuration
# ============================================
# Choose ONE of the following AI model configurations
# Uncomment and fill in the one you want to use

# --- Option 1: Google Gemini (Recommended) ---
# OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# OPENAI_API_KEY="your-gemini-api-key"
# MIDSCENE_MODEL_NAME="gemini-2.5-flash"
# MIDSCENE_USE_GEMINI=1

# --- Option 2: Doubao (ByteDance) ---
# OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# OPENAI_API_KEY="your-doubao-api-key"
# MIDSCENE_MODEL_NAME="doubao-1.5-thinking-pro"
# MIDSCENE_USE_DOUBAO_VISION=1

# --- Option 3: Qwen (Alibaba) ---
# OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# OPENAI_API_KEY="your-qwen-api-key"
# MIDSCENE_MODEL_NAME="qwen3-vl-plus"
# MIDSCENE_USE_QWEN3_VL=1

# ============================================
# AdsPower Browser (Web 测试复用已登录会话)
# ============================================
# 前置：AdsPower 客户端里手动登录好账号，并在 设置 → 本地 API 中开启服务。
# 本地 API 地址（默认即可，端口冲突时再改）
# ADSPOWER_API_URL=http://local.adspower.net:50325
# 如果开启了 API Key 校验，填这里
# ADSPOWER_API_KEY=your-adspower-api-key
# 各业务对应的 AdsPower 配置文件 ID（user_id），在 AdsPower 配置文件列表里查看
ADSPOWER_ESIM_USER_ID=your-esim-profile-id
ADSPOWER_FBGAME_USER_ID=your-fbgame-profile-id
# 不区分业务时的默认配置文件 ID（launchAdsPower 未显式传 userId 时回退到这里）
# ADSPOWER_USER_ID=your-default-profile-id

# eSIM 购买流程测试（搜索 → 结账 → My Orders）
ESIM_TEST_DESTINATION=Brazil
ESIM_TEST_CARD_NUMBER=4242424242424242
ESIM_TEST_CARD_EXPIRY=12/30
ESIM_TEST_CARD_CVC=123
ESIM_TEST_CARD_ZIP=65000

# ============================================
# Notification Configuration
# ============================================
# Feishu webhook for test result notifications
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Set to true to disable notifications during development
DISABLE_FEISHU_NOTIFY=true

# ============================================
# Report Hosting (Surge)
# ============================================
SURGE_EMAIL=your-email@example.com
SURGE_TOKEN=your-surge-token
SURGE_DOMAIN=midscene-test-report

# ============================================
# Android App Package Names
# ============================================
# Format: package.name/activity.name
ANDROID_SAUCE_PACKAGE=com.swaglabsmobileapp/com.swaglabsmobileapp.MainActivity

# ============================================
# iOS App Bundle IDs
# ============================================
IOS_MAIL_BUNDLE_ID=com.apple.mobilemail